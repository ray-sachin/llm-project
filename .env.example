# LLM Deployment Platform - Environment Configuration
# Copy this to .env and fill in your actual values

# ===== SUPABASE (Required) =====
# Get these from https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_KEY=your_service_role_key_here

# ===== FRONTEND =====
# URL where frontend is deployed (for CORS)
FRONTEND_URL=http://localhost:5173

# ===== GITHUB (Per-User Configuration) =====
# For multi-user setup, leave these empty
# Users will configure their own tokens via Settings page
GITHUB_TOKEN=
USERCODE=

# ===== AIPIPE (Per-User Configuration) =====
# Users provide their own AIPIPE token via Settings page
# Get from https://aipipe.org/login
AIPIPE_TOKEN=

# ===== API SECRET (Auto-generated) =====
# Used for signing tokens. Can be auto-generated if left empty
SECRET=

# ===== OPTIONAL =====
# Local development port (default: 8000)
API_PORT=8000
